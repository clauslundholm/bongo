# ---- Supabase ----
# Project URL and keys from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (SERVER ONLY — never expose to the browser).
# Used by the admin area for privileged reads/writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin allowlist ----
# Comma-separated list of emails allowed into /admin.
# Only these accounts (after signing up in Supabase Auth) can access the admin area.
ADMIN_EMAILS=claus@lundholm.com
