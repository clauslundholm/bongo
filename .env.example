# ---- Supabase ----
# Project URL and keys from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (SERVER ONLY — never expose to the browser).
# Used by the admin area for privileged reads/writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin allowlist (bootstrap) ----
# Comma-separated list of emails allowed into /admin.
# This is the BOOTSTRAP admin(s) — once you can log in, create more admins from
# admin → Administratorer (they're stored in the `admins` table). Keep at least
# one email here as a fallback in case the table is ever emptied.
ADMIN_EMAILS=claus@lundholm.com
